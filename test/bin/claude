#!/usr/bin/env node
/**
 * fake-claude — a deterministic stand-in for the real `claude` CLI, used by
 * paddock's server-integration + E2E tests so the WHOLE paddock + @herdctl/core
 * stack runs with ZERO Anthropic calls.
 *
 * ── Why a fake binary (and not a mock) ──────────────────────────────────────
 * herdctl's CLI runtime (@herdctl/core CLIRuntime) spawns `claude` from PATH and
 * then WATCHES the session JSONL file it writes — it does NOT read the process's
 * stdout for stream-json. So to exercise the real session-discovery / history /
 * resume machinery we must (a) be spawnable as `claude`, and (b) write a real
 * `<sessionId>.jsonl` transcript in the exact location + line shapes herdctl's
 * parser and the @herdctl/chat translator consume. This file does both.
 *
 * ── What herdctl passes us (see cli-runtime.ts) ─────────────────────────────
 *   claude -p --permission-mode <m> [--model <m>] [--system-prompt <s>]
 *          [--allowedTools <csv>] [--disallowedTools <csv>] [--resume <id>]
 *          [--mcp-config <json>] ...        (prompt arrives on STDIN)
 * cwd is the agent's working_directory. For a NEW session herdctl waits for a
 * NEW *.jsonl file to appear in getCliSessionDir(cwd) and derives the session id
 * from the filename. For --resume it watches <id>.jsonl directly. So:
 *   • new  → mint a uuid, write <uuid>.jsonl
 *   • resume → append to <resume>.jsonl
 *
 * ── Transcript line shapes (must match @herdctl/core jsonl-parser + chat) ───
 *   user line:      {type:"user", message:{role:"user", content:"<prompt>"},
 *                    sessionId, cwd, timestamp, version, gitBranch}
 *   assistant line: {type:"assistant",
 *                    message:{id, role:"assistant", model,
 *                             content:[{type:"text", text:"<reply>"}],
 *                             usage:{input_tokens, output_tokens,
 *                                    cache_read_input_tokens,
 *                                    cache_creation_input_tokens}},
 *                    sessionId, cwd, timestamp}
 *   result line:    {type:"result", subtype:"success", is_error:false,
 *                    session_id, result:"<reply>", usage:{...}}
 * The watcher yields each line as an SDKMessage; the chat translator extracts
 * assistant text → onText → WS chat:response; the jsonl-parser reads user +
 * assistant lines for history; the result line ends the watcher loop + marks
 * success. The first line is NEVER isSidechain:true (so discovery keeps it).
 *
 * ── Determinism / continuity ────────────────────────────────────────────────
 * Replies are scripted by prompt via a fixture map (PADDOCK_FAKE_SCRIPT, a JSON
 * file path, or the built-in rules below). On --resume the fake reads the prior
 * transcript so it can answer continuity questions (e.g. "what was the
 * codeword?" → the value set in an earlier turn) — this is what makes resume
 * *testable*.
 *
 * ── Prompt directives (opt-in extras for coverage) ──────────────────────────
 * These let server tests exercise the tool-call / message-boundary / sweep paths
 * WITHOUT changing any existing behavior (a prompt with none of these markers is
 * handled exactly as before). A directive is a literal token anywhere in the
 * prompt text:
 *   • [[TOOL]]      → emit a paired tool_use (assistant) + tool_result (user)
 *                     around the reply, so @herdctl/chat's translator surfaces a
 *                     chat:tool_call event.
 *   • [[BOUNDARY]]  → emit a SECOND assistant text block after a tool result, so
 *                     the translator fires onBoundary → chat:message_boundary.
 *   • [[HANG]]      → stream the assistant text, then block WITHOUT writing the
 *                     result line, leaving the turn "running" until the process
 *                     is killed. Lets a test exercise cancel/interrupt (Stop).
 * Sweeper coverage: when the prompt looks like the paddock sweeper's curation
 * prompt (contains the literal "<<<OVERVIEW>>>" marker request), the fake emits a
 * marker-shaped reply (<<<OVERVIEW>>> … <<<CHANGELOG>>> … <<<END>>>) so
 * SweepService can parse it and write OVERVIEW.md/CHANGELOG.md. The exact text is
 * overridable via PADDOCK_FAKE_SWEEP (a file path whose contents become the
 * sweeper reply).
 */
import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import crypto from "node:crypto";

// ── arg parsing ─────────────────────────────────────────────────────────────
function parseArgs(argv) {
  const flags = {
    print: false,
    model: undefined,
    systemPrompt: undefined,
    resume: undefined,
    permissionMode: undefined,
    allowedTools: undefined,
  };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === "-p" || a === "--print") flags.print = true;
    else if (a === "--model") flags.model = argv[++i];
    else if (a === "--system-prompt") flags.systemPrompt = argv[++i];
    else if (a === "--resume") flags.resume = argv[++i];
    else if (a === "--fork-session") flags.fork = true;
    else if (a === "--permission-mode") flags.permissionMode = argv[++i];
    else if (a === "--allowedTools") flags.allowedTools = argv[++i];
    else if (a === "--disallowedTools") argv[++i];
    else if (a === "--mcp-config") argv[++i];
    else if (a === "--setting-sources") argv[++i];
    else if (a === "--tools") argv[++i];
    // Unknown bare flags are ignored.
  }
  return flags;
}

function readStdin() {
  try {
    return fs.readFileSync(0, "utf8");
  } catch {
    return "";
  }
}

// ── session path (mirrors @herdctl/core cli-session-path.encodePathForCli) ──
function encodePathForCli(absolutePath) {
  return absolutePath.replace(/[/\\]/g, "-");
}
function sessionDirFor(cwd) {
  return path.join(os.homedir(), ".claude", "projects", encodePathForCli(cwd));
}

// ── scripted replies ────────────────────────────────────────────────────────
function loadScript() {
  const p = process.env.PADDOCK_FAKE_SCRIPT;
  if (!p) return {};
  try {
    return JSON.parse(fs.readFileSync(p, "utf8"));
  } catch {
    return {};
  }
}

/**
 * Decide the assistant reply for a prompt.
 *  1. Exact match in the JSON script (PADDOCK_FAKE_SCRIPT).
 *  2. Built-in rules: codeword set/recall (continuity), default echo.
 * `priorText` is the concatenated text of all prior transcript turns (used for
 * resume continuity).
 */
function replyFor(prompt, script, priorText) {
  const trimmed = (prompt || "").trim();
  if (Object.prototype.hasOwnProperty.call(script, trimmed)) {
    return script[trimmed];
  }

  // Sweeper curation prompt → emit a marker-shaped reply SweepService can parse.
  // Detected by the literal "<<<OVERVIEW>>>" the sweeper system/user prompt asks
  // for. Overridable via PADDOCK_FAKE_SWEEP (a file whose contents are the reply).
  if (trimmed.includes("<<<OVERVIEW>>>") || trimmed.includes("curating two files")) {
    return sweeperReply(trimmed);
  }

  // Continuity: "the codeword is X" / "remember the codeword: X"
  const setMatch = trimmed.match(/codeword(?:\s+is|:)\s+([A-Za-z0-9_-]+)/i);
  if (setMatch) {
    return `Got it — I'll remember the codeword ${setMatch[1]}.`;
  }
  // Recall: "what was the codeword?" → find it in the prior transcript text.
  // Prefer the normalized assistant phrasing ("...the codeword X.") written by
  // the set branch above; fall back to the user's "codeword is/was X".
  if (/what.*codeword/i.test(trimmed)) {
    const prior = priorText || "";
    const fromAssistant = prior.match(/remember the codeword\s+([A-Za-z0-9_-]+)/i);
    const fromUser = prior.match(/codeword(?:\s+is|\s+was|:)\s+([A-Za-z0-9_-]+)/i);
    const found = fromAssistant || fromUser;
    if (found) return `The codeword was ${found[1]}.`;
    return "I don't have a codeword on record.";
  }

  // Default: a short, deterministic acknowledgement that echoes the prompt so
  // tests can assert the text streamed through.
  return `Acknowledged: ${trimmed}`;
}

/**
 * Build the sweeper's marker-shaped reply (the two sections SweepService parses).
 * Overridable wholesale via PADDOCK_FAKE_SWEEP (a file path). The default echoes
 * a tiny, deterministic OVERVIEW + one changelog line.
 */
function sweeperReply(prompt) {
  const override = process.env.PADDOCK_FAKE_SWEEP;
  if (override) {
    try {
      return fs.readFileSync(override, "utf8");
    } catch {
      /* fall through to the default */
    }
  }
  return [
    "<<<OVERVIEW>>>",
    "# Project Overview",
    "",
    "Synthesized current state from recent activity.",
    "<<<CHANGELOG>>>",
    "Curated recent chat activity into the overview.",
    "<<<CLAUDE>>>",
    "- A durable convention discovered from recent activity.",
    "<<<END>>>",
  ].join("\n");
}

/** Concatenate prior assistant + user text from an existing transcript file. */
function readPriorText(file) {
  let raw = "";
  try {
    raw = fs.readFileSync(file, "utf8");
  } catch {
    return "";
  }
  const parts = [];
  for (const line of raw.split("\n")) {
    const t = line.trim();
    if (!t) continue;
    let o;
    try {
      o = JSON.parse(t);
    } catch {
      continue;
    }
    if (o.type !== "user" && o.type !== "assistant") continue;
    const c = o.message && o.message.content;
    if (typeof c === "string") parts.push(c);
    else if (Array.isArray(c)) {
      for (const b of c) if (b && b.type === "text" && typeof b.text === "string") parts.push(b.text);
    }
  }
  return parts.join("\n");
}

function nowIso() {
  return new Date().toISOString();
}

function sleep(ms) {
  // Synchronous-ish small delay so the watcher sees lines arrive incrementally.
  const end = Date.now() + ms;
  while (Date.now() < end) {
    /* spin briefly */
  }
}

function main() {
  const argv = process.argv.slice(2);
  const flags = parseArgs(argv);
  const prompt = readStdin();
  const cwd = process.cwd();
  const script = loadScript();

  const dir = sessionDirFor(cwd);
  try {
    fs.mkdirSync(dir, { recursive: true });
  } catch {
    /* the encoded path may be a symlink to <project>/.chats — that's fine */
  }

  // A FORK (`--resume <src> --fork-session`) mirrors real Claude Code: it resumes
  // the source's transcript as context but writes to a BRAND-NEW session file,
  // leaving the source untouched. A plain resume appends to the source file.
  const forking = !!(flags.fork && flags.resume);
  const resuming = !!flags.resume && !forking;
  const sessionId = resuming ? flags.resume : crypto.randomUUID();
  const file = path.join(dir, `${sessionId}.jsonl`);

  let priorText = "";
  if (forking) {
    // Seed the new file with the source's copied history (session ids rewritten
    // to the new id so the child is internally consistent + discoverable), then
    // fall through to append this turn — herdctl watches this new file for the
    // fork's id and skips the copied history. The source file is never touched.
    const srcFile = path.join(dir, `${flags.resume}.jsonl`);
    priorText = readPriorText(srcFile);
    try {
      const copied = fs
        .readFileSync(srcFile, "utf8")
        .split("\n")
        .filter((l) => l.trim())
        .map((l) => {
          try {
            const o = JSON.parse(l);
            if (o.sessionId) o.sessionId = sessionId;
            if (o.session_id) o.session_id = sessionId;
            return JSON.stringify(o);
          } catch {
            return l;
          }
        })
        .join("\n");
      if (copied) fs.writeFileSync(file, copied + "\n");
    } catch {
      /* source missing — behave like a fresh session */
    }
    // The forked file now exists with only the copied history. Pause so herdctl's
    // watcher detects the new file and initializes its read offset PAST that
    // history (it skips existing content on a fork/resume) BEFORE this turn's
    // lines are appended below — otherwise the reply is written before the
    // watcher starts and never streams. Real Claude Code has the same ordering:
    // it copies the session, then takes real time to produce the new turn. The
    // delay must exceed cli-runtime's waitForNewSessionFile poll interval (200ms).
    sleep(350);
  } else if (resuming) {
    priorText = readPriorText(file);
  }
  const reply = replyFor(prompt, script, priorText);
  const model = flags.model || "claude-opus-4-8";

  const append = (obj) => {
    fs.appendFileSync(file, JSON.stringify(obj) + "\n");
  };

  // 1) user line (preview + history). Never isSidechain (keep it discoverable).
  append({
    parentUuid: null,
    isSidechain: false,
    type: "user",
    message: { role: "user", content: prompt },
    uuid: crypto.randomUUID(),
    timestamp: nowIso(),
    cwd,
    sessionId,
    version: "2.1.167",
    gitBranch: "",
    userType: "external",
  });

  // Small gap so the watcher streams the assistant separately from the user line.
  sleep(60);

  const usage = {
    input_tokens: 1200,
    output_tokens: 64,
    cache_read_input_tokens: 0,
    cache_creation_input_tokens: 0,
  };
  const assistantText = (text) => ({
    parentUuid: null,
    isSidechain: false,
    type: "assistant",
    message: {
      id: `msg_${crypto.randomBytes(8).toString("hex")}`,
      role: "assistant",
      model,
      content: [{ type: "text", text }],
      usage,
    },
    uuid: crypto.randomUUID(),
    timestamp: nowIso(),
    cwd,
    sessionId,
  });

  // Opt-in directives (see header): emit a tool_use/tool_result pair and/or a
  // second assistant text block (boundary). A prompt with neither marker is
  // handled exactly as before — a single assistant text line.
  const wantsTool = (prompt || "").includes("[[TOOL]]");
  const wantsBoundary = (prompt || "").includes("[[BOUNDARY]]");

  if (wantsTool) {
    // 2a) assistant turn carrying a tool_use block (the translator tracks it).
    const toolUseId = `toolu_${crypto.randomBytes(8).toString("hex")}`;
    append({
      parentUuid: null,
      isSidechain: false,
      type: "assistant",
      message: {
        id: `msg_${crypto.randomBytes(8).toString("hex")}`,
        role: "assistant",
        model,
        content: [{ type: "tool_use", id: toolUseId, name: "Read", input: { file_path: "notes.md" } }],
        usage,
      },
      uuid: crypto.randomUUID(),
      timestamp: nowIso(),
      cwd,
      sessionId,
    });
    sleep(30);
    // 2b) the paired tool_result, on a user line (the translator pairs them →
    // chat:tool_call). A tool result also resets the boundary text flag.
    append({
      parentUuid: null,
      isSidechain: false,
      type: "user",
      message: {
        role: "user",
        content: [
          { type: "tool_result", tool_use_id: toolUseId, content: "file contents here", is_error: false },
        ],
      },
      uuid: crypto.randomUUID(),
      timestamp: nowIso(),
      cwd,
      sessionId,
    });
    sleep(30);
  }

  // 2) assistant line (text + usage). Single text block → one chat:response.
  append(assistantText(reply));

  // [[HANG]] (test-only): stream the assistant text, then block WITHOUT writing
  // the result line — the turn stays "running" until herdctl aborts and kills
  // this process. Exercises the cancel/interrupt path end-to-end (cancelJob →
  // AbortController → subprocess.kill). Keep the event loop alive with a pending
  // timer so the SIGTERM from that kill terminates us promptly — a synchronous
  // spin-loop would swallow the signal.
  if ((prompt || "").includes("[[HANG]]")) {
    setInterval(() => {}, 1 << 30);
    return;
  }

  // A second assistant text block produces a message_boundary in the translator
  // (a new assistant turn after a previous text run). Requires a preceding text
  // run OR a tool result to have reset the flag; the [[TOOL]] path provides one,
  // and a plain [[BOUNDARY]] gets the boundary from the first → second text run.
  // Use a generous gap so the (polling) chokidar watcher reads the two assistant
  // lines as SEPARATE appends — otherwise they batch into one read and the
  // translator never sees a second distinct assistant turn (no boundary).
  if (wantsBoundary) {
    sleep(250);
    append(assistantText("(boundary follow-up)"));
  }

  sleep(40);

  // 3) result line — ends the watcher loop and marks the turn successful.
  append({
    type: "result",
    subtype: "success",
    is_error: false,
    session_id: sessionId,
    result: reply,
    usage: {
      input_tokens: 1200,
      output_tokens: 64,
      cache_read_input_tokens: 0,
      cache_creation_input_tokens: 0,
    },
  });

  // Mirror the reply to stdout (the runtime logs it; harmless) and exit cleanly.
  process.stdout.write(reply + "\n");
  process.exit(0);
}

main();

# Paddock server configuration. Copy to .env and adjust. All optional —
# sane defaults are applied (see packages/server/src/config.ts).

# HTTP/WS port and bind host for paddock-server.
PORT=4000
HOST=0.0.0.0

# Data root. Projects, scratch dir, generated herdctl config, and the .herdctl
# state dir all default to subdirectories of this.
PADDOCK_DATA_DIR=./data

# Override individual paths if needed (absolute or relative to cwd):
# PADDOCK_PROJECTS_DIR=./data/projects
# PADDOCK_STATE_DIR=./data/.herdctl
# PADDOCK_HERDCTL_CONFIG=./data/herdctl.yaml
# PADDOCK_SCRATCH_DIR=./data/scratch

# Built web SPA served in production (defaults to packages/web/dist).
# PADDOCK_WEB_DIST=./packages/web/dist

# Claude auth for the keeper agents (runtime: cli, Max plan). The `claude` CLI
# must be on PATH and authenticated. Set in the deploy environment, not here.
# CLAUDE_CODE_OAUTH_TOKEN=...

# Fastify log level.
# LOG_LEVEL=info

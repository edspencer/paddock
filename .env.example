# Paddock server configuration. Copy to .env and adjust. All optional —
# sane defaults are applied (see packages/server/src/config.ts).
#
# Full reference (every var, default, and purpose): docs/CONFIGURATION.md

# HTTP/WS port and bind host for paddock-server.
PORT=4000
HOST=0.0.0.0

# Data root. Projects, scratch dir, generated herdctl config, and the .herdctl
# state dir all default to subdirectories of this.
PADDOCK_DATA_DIR=./data

# Override individual paths if needed (absolute or relative to cwd):
# PADDOCK_PROJECTS_DIR=./data/projects
# PADDOCK_STATE_DIR=./data/.herdctl
# PADDOCK_HERDCTL_CONFIG=./data/herdctl.yaml
# PADDOCK_SCRATCH_DIR=./data/scratch

# Built web SPA served in production (defaults to packages/web/dist).
# PADDOCK_WEB_DIST=./packages/web/dist

# Claude auth for the keeper agents (runtime: cli, Max plan). The server reads
# CLAUDE_CODE_OAUTH_TOKEN from its own process environment and passes it through
# to the spawned `claude` CLI — it is NEVER hardcoded in config. The `claude`
# CLI must be on PATH. Set this in the deploy environment (e.g. the LXC), not
# committed here.
# CLAUDE_CODE_OAUTH_TOKEN=...
#
# Alternatively, use the SDK runtime with an Anthropic API key (API pricing).
# Provide CLAUDE_CODE_OAUTH_TOKEN *or* ANTHROPIC_API_KEY.
# ANTHROPIC_API_KEY=...

# Note: keeper/scratch agent working directories are canonicalized (symlinks
# resolved) at startup so Claude Code session discovery can find transcripts.
# On macOS this maps /tmp -> /private/tmp; on the Linux deploy target it is a
# no-op. No action needed.

# ---------------------------------------------------------------------------
# User authentication (provider-agnostic). See AUTH.md for the full guide.
#
# Paddock has no login of its own — it sits behind a reverse proxy that has
# already authenticated the user (Authentik, oauth2-proxy, Authelia, Cloudflare
# Access, Keycloak, …). These knobs turn that upstream identity into a
# `req.user`, WITHOUT hardcoding any single provider. All optional; default is
# `none` (fully open). Health probes are always exempt.

# Mode: none | trusted-header | jwt
# PADDOCK_AUTH_MODE=none

# --- trusted-header mode ---------------------------------------------------
# Trust the proxy to pass identity in header(s). Spoofable unless the proxy is
# the ONLY network path to paddock. Username header is required in this mode;
# email/groups are optional. (Groups header is comma/space-split.)
# PADDOCK_AUTH_USER_HEADER=X-Forwarded-User      # or Remote-User / X-authentik-username
# PADDOCK_AUTH_EMAIL_HEADER=X-Forwarded-Email
# PADDOCK_AUTH_GROUPS_HEADER=X-Forwarded-Groups

# --- jwt mode (zero-trust, spoof-proof) ------------------------------------
# Verify a signed JWT against the IdP's JWKS. Paddock holds only the JWKS URL,
# never key material; it validates signature (and issuer/audience if set) itself.
# PADDOCK_AUTH_JWT_HEADER=Authorization          # header carrying the token; `Authorization` strips a leading `Bearer `
# PADDOCK_AUTH_JWKS_URL=                         # REQUIRED in jwt mode
# PADDOCK_AUTH_JWT_ISSUER=                       # optional: validate `iss`
# PADDOCK_AUTH_JWT_AUDIENCE=                     # optional: validate `aud`
# PADDOCK_AUTH_USERNAME_CLAIM=                   # optional; default tries preferred_username → email → sub
# PADDOCK_AUTH_GROUPS_CLAIM=groups               # optional; default `groups`

# Our Authentik forward-auth deployment (jwt mode). Set JWKS_URL to the
# per-application JWKS endpoint (slug = the Authentik application slug):
# PADDOCK_AUTH_MODE=jwt
# PADDOCK_AUTH_JWT_HEADER=X-authentik-jwt
# PADDOCK_AUTH_JWKS_URL=https://sso.valfenda.net/application/o/<app-slug>/jwks/

# Fastify log level (fatal|error|warn|info|debug|trace).
# LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Per-instance branding (defaults preserve today's look: 🐎 / Paddock /
# terracotta). Set these to tell several instances apart.
# PADDOCK_BRAND_NAME=Paddock
# PADDOCK_BRAND_LOGO=🐎                 # emoji/glyph, or a URL/path to an image
# PADDOCK_BRAND_ACCENT=#c2603c          # hex accent color

# ---------------------------------------------------------------------------
# Voice dictation (Whisper). Off unless configured; then a mic button appears
# in the composer. See DEV.md. Mode auto-selects `remote` when an endpoint is set.
# PADDOCK_WHISPER_MODE=off              # off | remote | local
# PADDOCK_WHISPER_ENDPOINT=             # remote: OpenAI-compatible base URL
# PADDOCK_WHISPER_API_KEY=              # remote: optional bearer token
# PADDOCK_WHISPER_MODEL=base            # tiny|base|small|… (.en = English-only)
# PADDOCK_WHISPER_LANGUAGE=             # e.g. en; unset ⇒ auto-detect
# PADDOCK_WHISPER_MAX_UPLOAD_BYTES=26214400   # 25 MiB

# ---------------------------------------------------------------------------
# Keeper / agents.
# PADDOCK_KEEPER_DRIVE_MODE=batch       # batch | session (session = cross-turn autonomy)
# PADDOCK_KEEPER_NATIVE_PROMPT=true     # false ⇒ terse Paddock replace prompt
# PADDOCK_SELF_MCP=false                # read-only self-management MCP for keepers
# PADDOCK_SELF_MCP_WRITE=false          # + write tools (only if PADDOCK_SELF_MCP=1)
# PADDOCK_BROWSER_MCP=                  # =1 injects a headless Playwright MCP

# ---------------------------------------------------------------------------
# Dev servers / git / GitHub.
# PADDOCK_DEV_SERVERS_ENABLED=false     # advertise the on-box `pm` capability
# PADDOCK_DEV_SERVERS_DOMAIN=projects.valfenda.net
# PADDOCK_GIT_AUTHOR_NAME=Paddock       # author for server-made commits
# PADDOCK_GIT_AUTHOR_EMAIL=paddock@localhost
# PADDOCK_GITHUB_CLIENT_ID=             # enables the GitHub device-flow connect

# ---------------------------------------------------------------------------
# Advanced.
# PADDOCK_SWEEP_MIN_INTERVAL_MS=        # min ms between post-turn sweeps (unset ⇒ no throttle)
